# SIT 环境认证配置模板
# 复制此文件为 sit-auth.yaml 并填写实际信息
# 注意: sit-auth.yaml 应加入 .gitignore

# SIT 环境地址
sit_url: http://pri-fssc-web-sit.digitalyili.com

# UAT 环境地址
uat_url: http://pri-fssc-web-uat.digitalyili.com

# 认证方式1: 账号密码 (兜底方案)
username: fsscadmin
password: "2"

# 认证方式2: Cookie 文件路径 (降级方案)
# 使用 browser-use cookies export sit-cookies.json 导出
cookie_file: config/sit-cookies.json

# Chrome Profile 名称 (优先方案)
# 使用 browser-use profile list 查看可用 Profile
chrome_profile: Default

# Playwright storageState 路径 (用于 Playwright 测试)
# 首次手动登录后保存: npx playwright codegen --save-storage=config/sit-storage.json
storage_state: config/sit-storage.json
